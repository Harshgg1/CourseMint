generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               Int      @id @default(autoincrement())
  username         String   @unique
  password         String
  purchasedCourses Course[] @relation("UserCourses")
}

model Admin {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}

model Course {
  id          Int     @id @default(autoincrement())
  title       String
  description String
  price       Float
  imageLink   String?
  published   Boolean @default(false)
  users       User[]  @relation("UserCourses")
}
